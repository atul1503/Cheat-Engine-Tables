      <Description>"MAIN"</Description>
      <Options moAllowManualCollapseAndExpand="1"/>
      <GroupHeader>1</GroupHeader>
      <CheatEntries>
        <CheatEntry>
          <ID>28</ID>
          <Description>"SCRIPTS"</Description>
          <Options moAllowManualCollapseAndExpand="1"/>
          <GroupHeader>1</GroupHeader>
          <CheatEntries>
            <CheatEntry>
              <ID>27</ID>
              <Description>"Fast run/walk"</Description>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{ Game   : witcher3.exe
  Author : atult
  Description: Single multiplier broadcast for X, Y, Z deltas at [rbx]
  Makes you run/walk fast.

}

[ENABLE]

aobscanmodule(INJECT,witcher3.exe,F3 0F 10 03 0F 28 F9)
alloc(newmem,$1000,INJECT)

label(code)
label(return)
label(multiplier)

newmem:

code:
  // Stack alignment (32 bytes) for SIMD operations
  sub rsp,20
  movdqu [rsp],xmm15

  // 1. Load single float value into lowest slot of xmm15
  movss xmm15,[multiplier]

  // 2. Broadcast that single value across all 4 float slots of xmm15
  shufps xmm15,xmm15,00

  // 3. Multiply [rbx] (X, Y, Z) by the broadcasted xmm15
  movups xmm0,[rbx]
  mulps xmm0,xmm15
  movups [rbx],xmm0

  // Restore xmm15 and clean up stack
  movdqu xmm15,[rsp]
  add rsp,20

  // Original instructions
  movss xmm0,[rbx]
  movaps xmm7,xmm1
  jmp return

multiplier:
  dd (float)3.0

INJECT:
  jmp newmem
  nop 2
return:
registersymbol(INJECT)

[DISABLE]

INJECT:
  db F3 0F 10 03 0F 28 F9

unregistersymbol(INJECT)
dealloc(newmem)
</AssemblerScript>
            </CheatEntry>
          </CheatEntries>
